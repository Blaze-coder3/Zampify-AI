# Zampify AI — Environment Configuration
# Copy this file to .env and fill in your values

# App
DEBUG=true
SECRET_KEY=zampify-secret-change-in-production-use-32-char-random

# Database (PostgreSQL — run locally or in Docker)
DATABASE_URL=postgresql+asyncpg://zampify:zampify@localhost:5432/zampify
DATABASE_SYNC_URL=postgresql://zampify:zampify@localhost:5432/zampify

# Redis (run on Docker as per setup)
REDIS_URL=redis://localhost:6379

# FeatherlessAI — paste your API key here
FEATHERLESS_API_KEY=your_featherless_api_key_here
FEATHERLESS_BASE_URL=https://api.featherless.ai/v1
FEATHERLESS_MODEL=meta-llama/Llama-3.3-70B-Instruct

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10

# Policy
POLICY_FILE=./app/policies/policies.yaml
