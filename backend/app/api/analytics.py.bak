    Returns data for the Bottleneck Heatmap dashboard.
    """
    # KPIs
    kpis = {
        "avg_cycle_time": {"value": 2.4, "unit": "days", "trend": 18.6, "up": False}, # false = bad (up is bad for cycle time here? well in mockup it's red/orange up arrow. Let's pass trend string and color explicitly in frontend instead of 'up' logic for this specific page to match mockup)
        "max_cycle_time": {"value": 12.6, "unit": "days", "trend": 15.2, "up": False},
        "pct_in_bottleneck": {"value": 32.8, "unit": "%", "trend": 6.7, "up": False},
